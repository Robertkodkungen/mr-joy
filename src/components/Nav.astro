---
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

const links = [
	{ href: '/', label: 'Hem' },
	{ href: '/mr-joys-dagbok', label: 'Dagbok' },
	{ href: '/om-mr-joy', label: 'Om' },
	{ href: '/snacka-med-mr-joy', label: 'Snacka' },
];

function isCurrent(href: string): boolean {
	if (href === '/') return pathname === '/';
	return pathname === href || pathname.startsWith(`${href}/`);
}
---

<nav class="site-nav" aria-label="Huvudmeny">
	<div class="site-nav__inner">
		<a class="site-nav__brand site-nav__brand--logo" href="/">
			<img
				class="site-nav__brand-img"
				src="/images/mr-joy-portrait.png"
				alt=""
				width="48"
				height="48"
				decoding="async"
			/>
			<span>Mr.Joy</span>
		</a>
		<ul class="site-nav__links">
			{
				links.map(({ href, label }) => (
					<li>
						<a href={href} aria-current={isCurrent(href) ? 'page' : undefined}>
							{label}
						</a>
					</li>
				))
			}
		</ul>
	</div>
</nav>
