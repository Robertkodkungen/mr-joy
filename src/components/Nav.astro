---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

const links = [
	{ href: `${base}/`, label: 'Hem' },
	{ href: `${base}/mr-joys-dagbok`, label: 'Dagbok' },
	{ href: `${base}/om-mr-joy`, label: 'Om' },
	{ href: `${base}/snacka-med-mr-joy`, label: 'Snacka' },
];

function isCurrent(href: string): boolean {
	const clean = href.replace(/\/$/, '') || '/';
	if (clean === base || clean === `${base}/`) return pathname === base || pathname === `${base}/`;
	return pathname === clean || pathname.startsWith(`${clean}/`);
}
---

<nav class="site-nav" aria-label="Huvudmeny">
	<div class="site-nav__inner">
		<a class="site-nav__brand site-nav__brand--logo" href={`${base}/`}>
			<img
				class="site-nav__brand-img"
				src={`${base}/images/mr-joy-portrait.png`}
				alt=""
				width="48"
				height="48"
				decoding="async"
			/>
			<span>Mr.Joy</span>
		</a>
		<ul class="site-nav__links">
			{
				links.map(({ href, label }) => (
					<li>
						<a href={href} aria-current={isCurrent(href) ? 'page' : undefined}>
							{label}
						</a>
					</li>
				))
			}
		</ul>
	</div>
</nav>
